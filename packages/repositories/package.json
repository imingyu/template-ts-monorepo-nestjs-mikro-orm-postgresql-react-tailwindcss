{
    "name": "@mono-ts/repositories",
    "version": "0.1.0",
    "description": "DB entity repositories",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "pnpm clean:all",
        "clean:all": "pnpm clean:cache && pnpm clean:build && pnpm clean:deps",
        "clean:cache": "rimraf .turbo && rimraf tsconfig.tsbuildinfo",
        "clean:deps": "rimraf node_modules",
        "clean:build": "rimraf dist && rimraf build",
        "check-types": "tsc --noEmit",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "test": "dotenvx run -f .env.dev -- vitest run",
        "test:watch": "dotenvx run -f .env.dev -- vitest watch",
        "coverage": "dotenvx run -f .env.dev -- vitest run --coverage",
        "test:ui": "dotenvx run -f .env.dev -- vitest --ui"
    },
    "devDependencies": {
        "@dotenvx/dotenvx": "^2.14.0",
        "@mono-ts/config-tools": "workspace:*",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^26.1.1",
        "@vitest/coverage-v8": "^4.1.10",
        "@vitest/ui": "^4.1.10",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "oxlint-tsgolint": "^0.25.0",
        "rimraf": "^6.1.3",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "@mikro-orm/core": "^7.1.7",
        "@mikro-orm/decorators": "^7.1.7",
        "@mikro-orm/mysql": "^7.1.7",
        "@mikro-orm/postgresql": "^7.1.7",
        "@mono-ts/shared": "workspace:*",
        "@mono-ts/types": "workspace:*",
        "lodash-es": "^4.18.1"
    }
}
