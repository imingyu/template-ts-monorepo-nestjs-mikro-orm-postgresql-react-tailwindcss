{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": ["./base.tsconfig.json"],
    "compilerOptions": {
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2023"],
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "moduleSuffixes": [],
        "isolatedModules": true
    }
}
